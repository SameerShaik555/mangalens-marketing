---
import Layout from '../../layouts/Layout.astro';
import { site, CHROME_STORE_URL, DISCORD_URL } from '../../data/content';

const pageTitle = `${site.name} vs Fakey — Which Manga Translator is Better?`;
const pageDescription = `Compare ${site.name} vs Fakey manga translator. Honest comparison of features, pricing, languages, and privacy. Discover why MangaLens offers unlimited translations at a flat price with 65+ languages.`;


---

<Layout title={pageTitle} description={pageDescription}>
  <!-- ============================ HEADER ============================ -->
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/" aria-label={`${site.name} home`}>
        <span class="brand-mark">🔍</span>
        <span class="brand-name">{site.name}</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="#languages">Languages</a>
        <a href="#privacy">Privacy</a>
      </nav>
      <a class="btn btn-primary btn-sm js-cta" data-cta="header" href={CHROME_STORE_URL}>
        Try {site.name} Free
      </a>
    </div>
  </header>

  <main>
    <!-- ============================ HERO ============================ -->
    <section class="hero">
      <div class="container hero-inner">
        <span class="eyebrow">Comparison</span>
        <h1 class="hero-title">
          <span class="gradient-text">{site.name}</span> vs Fakey
        </h1>
        <p class="hero-sub">
          Searching for a Fakey alternative? Here's an honest comparison of features, pricing, languages, and privacy so you can choose the best manga translator for your reading.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary js-cta" data-cta="hero-primary" href={CHROME_STORE_URL}>
            ⚡ Try {site.name} Free — 200 Translations
          </a>
          <a class="btn btn-ghost" href="/">{site.name} Home</a>
        </div>
      </div>
    </section>

    <!-- ============================ QUICK VERDICT ============================ -->
    <section class="section section-alt">
      <div class="container narrow center">
        <span class="eyebrow">Quick Verdict</span>
        <h2>Choose {site.name} if you want...</h2>
        <div class="verdict-grid">
          <div class="card verdict">
            <h3>✓ Unlimited Translations</h3>
            <p class="muted">Translate as much as you want with flat pricing — no credits, no counters, no surprise fees.</p>
          </div>
          <div class="card verdict">
            <h3>✓ Website Integration</h3>
            <p class="muted">Works directly on your favorite manga sites without switching apps or uploading images.</p>
          </div>
          <div class="card verdict">
            <h3>✓ Privacy First</h3>
            <p class="muted">Images are never stored. Your reading history stays completely private.</p>
          </div>
          <div class="card verdict">
            <h3>✓ Long-Tail Languages</h3>
            <p class="muted">65+ languages including Thai, Vietnamese, Indonesian, and other regional languages.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================ COMPARISON TABLE ============================ -->
    <section id="features" class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Side-by-Side Comparison</span>
          <h2>Feature-by-Feature Comparison</h2>
        </div>

        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Feature</th>
                <th class="col-mangalens">{site.name}</th>
                <th class="col-fakey">Fakey</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Pricing Model</strong></td>
                <td class="col-mangalens"><strong>Flat monthly/yearly subscription</strong><br><span class="muted">Unlimited translations, no credit counters</span></td>
                <td class="col-fakey">In-app purchases<br><span class="muted">Premium features require additional purchases</span></td>
              </tr>
              <tr>
                <td><strong>Translation Volume</strong></td>
                <td class="col-mangalens"><strong>Unlimited</strong><br><span class="muted">Translate as much as you want</span></td>
                <td class="col-fakey">Premium tier claims unlimited<br><span class="muted">But behind paywall/credits system</span></td>
              </tr>
              <tr>
                <td><strong>How It Works</strong></td>
                <td class="col-mangalens"><strong>Browser extension</strong><br><span class="muted">One-click translation on any manga website</span></td>
                <td class="col-fakey">App + browser extension<br><span class="muted">Point-and-read or image upload</span></td>
              </tr>
              <tr>
                <td><strong>Languages</strong></td>
                <td class="col-mangalens"><strong>65+ languages</strong><br><span class="muted">Including long-tail Asian languages</span></td>
                <td class="col-fakey">131+ languages claimed<br><span class="muted">Broader language support</span></td>
              </tr>
              <tr>
                <td><strong>Bubble Detection</strong></td>
                <td class="col-mangalens"><strong>Advanced AI</strong><br><span class="muted">Handles hand-drawn and irregular shapes</span></td>
                <td class="col-fakey">AI-powered<br><span class="muted">Real-time translation</span></td>
              </tr>
              <tr>
                <td><strong>Privacy Policy</strong></td>
                <td class="col-mangalens"><strong>Images never stored</strong><br><span class="muted">Processed on secure server, zero retention</span></td>
                <td class="col-fakey">Unknown<br><span class="muted">Privacy policy not clearly documented</span></td>
              </tr>
              <tr>
                <td><strong>Batch Processing</strong></td>
                <td class="col-mangalens">Whole-page translation<br><span class="muted">All bubbles on page at once</span></td>
                <td class="col-fakey">Up to 10 images per job<br><span class="muted">Manual upload required</span></td>
              </tr>
              <tr>
                <td><strong>Manga Site Support</strong></td>
                <td class="col-mangalens"><strong>100s of websites</strong><br><span class="muted">MangaDex, Webtoon, Rawkuma, Comic Days, + hundreds more</span></td>
                <td class="col-fakey">App-focused<br><span class="muted">Requires uploading or using mobile app</span></td>
              </tr>
              <tr>
                <td><strong>Free Trial</strong></td>
                <td class="col-mangalens"><strong>200 free translations</strong><br><span class="muted">No credit card required</span></td>
                <td class="col-fakey">Basic features free<br><span class="muted">Premium features locked</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ============================ WHERE FAKEY WINS ============================ -->
    <section class="section section-alt">
      <div class="container narrow">
        <div class="section-head">
          <span class="eyebrow">Fair Comparison</span>
          <h2>Where Fakey Excels</h2>
        </div>
        <p class="muted">
          {site.name} is committed to honest marketing. Here's where Fakey has genuine advantages:
        </p>
        <div class="pros-list">
          <div class="pro-item">
            <div class="pro-icon">✓</div>
            <div>
              <h3>Broader Language Reach</h3>
              <p class="muted">Fakey claims 131+ languages, which is genuinely broader coverage if you need less common languages.</p>
            </div>
          </div>
          <div class="pro-item">
            <div class="pro-icon">✓</div>
            <div>
              <h3>Mobile App</h3>
              <p class="muted">Fakey has dedicated iOS and Android apps, which is convenient if you prefer reading on mobile.</p>
            </div>
          </div>
          <div class="pro-item">
            <div class="pro-icon">✓</div>
            <div>
              <h3>Image Upload Flexibility</h3>
              <p class="muted">Batch upload up to 10 images is useful if you have downloaded manga files to translate.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================ WHERE MANGALENS WINS ============================ -->
    <section class="section">
      <div class="container narrow">
        <div class="section-head">
          <span class="eyebrow">Why {site.name}</span>
          <h2>Why Manga Readers Choose {site.name}</h2>
        </div>
        <div class="pros-list">
          <div class="pro-item featured">
            <div class="pro-icon">⚡</div>
            <div>
              <h3>Flat Pricing, No Surprise Fees</h3>
              <p class="muted">Pay once monthly or yearly. Unlimited translations. No credits, no counters, no worrying about hitting a limit mid-chapter.</p>
            </div>
          </div>
          <div class="pro-item featured">
            <div class="pro-icon">🌐</div>
            <div>
              <h3>Works on Your Favorite Sites</h3>
              <p class="muted">No app switching, no image uploading. Just click the extension on MangaDex, Webtoon, Rawkuma, or 100s of other sites.</p>
            </div>
          </div>
          <div class="pro-item featured">
            <div class="pro-icon">🔒</div>
            <div>
              <h3>Privacy You Can Trust</h3>
              <p class="muted">Images are processed on our secure server and <strong>never stored</strong>. Your reading history stays private. No mystery data practices.</p>
            </div>
          </div>
          <div class="pro-item featured">
            <div class="pro-icon">🗣️</div>
            <div>
              <h3>Long-Tail Asian Languages</h3>
              <p class="muted">Strong support for Thai, Vietnamese, Indonesian, and other regional languages that matter to manga readers across Southeast Asia.</p>
            </div>
          </div>
          <div class="pro-item featured">
            <div class="pro-icon">⚡</div>
            <div>
              <h3>One-Click Whole-Page Translation</h3>
              <p class="muted">Translate every speech bubble on a page instantly. No manual selection, no uploading images one by one.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================ PRICING BREAKDOWN ============================ -->
    <section id="pricing" class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Pricing</span>
          <h2>Pricing Comparison</h2>
        </div>

        <div class="pricing-comparison">
          <div class="card pricing-card pricing-featured">
            <div class="pricing-badge">Recommended</div>
            <h3>{site.name}</h3>
            <div class="pricing-model">
              <div class="price-row">
                <span class="price-label">Monthly</span>
                <span class="price-value">$4.99/month</span>
              </div>
              <div class="price-row">
                <span class="price-label">Yearly</span>
                <span class="price-value">$49.99/year</span>
                <span class="price-save">Save 17%</span>
              </div>
            </div>
            <ul class="pricing-features">
              <li>✓ Unlimited translations</li>
              <li>✓ All 65+ languages</li>
              <li>✓ Every supported manga site</li>
              <li>✓ 200 free translations to try</li>
              <li>✓ Cancel anytime</li>
            </ul>
            <a class="btn btn-primary js-cta" data-cta="pricing-mangalens" href={CHROME_STORE_URL}>
              Try {site.name} Free
            </a>
          </div>

          <div class="card pricing-card">
            <h3>Fakey</h3>
            <div class="pricing-model">
              <div class="price-row">
                <span class="price-label">Basic</span>
                <span class="price-value">Free</span>
              </div>
              <div class="price-row">
                <span class="price-label">Premium</span>
                <span class="price-value">In-app purchases</span>
              </div>
            </div>
            <ul class="pricing-features">
              <li>✓ Basic features free</li>
              <li>? Unlimited (behind paywall)</li>
              <li>✓ 131+ languages</li>
              <li>✓ Mobile apps</li>
              <li>✓ Image upload</li>
            </ul>
            <p class="muted pricing-note">
              <strong>Note:</strong> Exact premium pricing not clearly documented. Requires in-app purchases for full features.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================ FINAL CTA ============================ -->
    <section class="final-cta">
      <div class="container center">
        <h2>Ready to Switch from Fakey?</h2>
        <p class="muted">Try {site.name} with 200 free translations — no credit card required. See why manga readers are making the switch.</p>
        <a class="btn btn-primary btn-lg js-cta" data-cta="final" href={CHROME_STORE_URL}>
          ⚡ Try {site.name} Free — 200 Translations
        </a>
        <p class="muted" style="margin-top: 20px; font-size: 14px;">
          Questions? <a href={DISCORD_URL} style="text-decoration: underline;">Join our Discord</a> to talk with the team and other manga readers.
        </p>
      </div>
    </section>
  </main>

  <!-- ============================ FOOTER ============================ -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="brand-mark">🔍</span>
        <span class="brand-name">{site.name}</span>
        <p class="muted footer-tag">{site.tagline}</p>
      </div>
      <nav class="footer-links" aria-label="Footer">
        <a href="/">Home</a>
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a class="js-cta" data-cta="footer-discord" href={DISCORD_URL}>💬 Join Discord</a>
        <a class="js-cta" data-cta="footer-store" href={CHROME_STORE_URL}>Add to Chrome</a>
      </nav>
    </div>
    <div class="container footer-legal muted">
      © {new Date().getFullYear()} {site.name}. All rights reserved.
    </div>
  </footer>
</Layout>

<style>
  /* ----------------------------- Header ----------------------------- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(11, 11, 18, 0.7);
    border-bottom: 1px solid var(--border);
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; height: 66px; gap: 16px; }
  .brand { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 18px; }
  .brand-mark { font-size: 20px; }
  .nav-links { display: flex; gap: 28px; font-weight: 500; color: var(--muted); }
  .nav-links a:hover { color: var(--text); }
  .btn-sm { padding: 9px 18px; font-size: 14px; }
  @media (max-width: 760px) { .nav-links { display: none; } }

  /* ------------------------------ Hero ------------------------------ */
  .hero { position: relative; padding: 80px 0 64px; overflow: hidden; }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(60% 50% at 50% 0%, rgba(124, 58, 237, 0.25), transparent 70%),
      radial-gradient(40% 40% at 80% 10%, rgba(236, 72, 153, 0.18), transparent 70%);
    pointer-events: none;
  }
  .hero-inner { position: relative; text-align: center; max-width: 820px; margin: 0 auto; }
  .hero-title { font-size: clamp(40px, 7vw, 72px); font-weight: 900; }
  .hero-sub { font-size: clamp(17px, 2.4vw, 21px); margin: 22px auto 0; max-width: 620px; }
  .hero-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-top: 32px; }

  /* --------------------------- Section heads ------------------------ */
  .section-alt { background: var(--bg-soft); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .section-head { text-align: center; max-width: 640px; margin: 0 auto 48px; }
  .section-head h2 { font-size: clamp(28px, 4.4vw, 42px); font-weight: 800; margin-bottom: 14px; }
  .narrow { max-width: 760px; }
  .center { text-align: center; }

  /* ------------------------------ Cards ----------------------------- */
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 26px; }

  /* -------------------------- Verdict Grid ------------------------- */
  .verdict-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 40px; }
  .verdict h3 { font-size: 18px; margin-bottom: 8px; color: var(--brand-2); }
  .verdict p { font-size: 15px; }
  @media (max-width: 720px) { .verdict-grid { grid-template-columns: 1fr; } }

  /* ------------------------ Comparison Table ---------------------- */
  .comparison-table-wrapper { overflow-x: auto; margin: 40px 0; }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .comparison-table th, .comparison-table td {
    padding: 20px 24px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }
  .comparison-table th {
    font-weight: 800;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--bg-soft);
  }
  .comparison-table th:first-child { width: 25%; }
  .comparison-table th:not(:first-child) { width: 37.5%; }
  .comparison-table tr:last-child td { border-bottom: none; }
  .comparison-table tr:hover { background: rgba(124, 58, 237, 0.03); }

  .col-mangalens { color: var(--brand-2); font-weight: 700; }
  .col-fakey { color: var(--text); font-weight: 600; }

  .comparison-table td strong { display: block; margin-bottom: 4px; }
  .comparison-table td .muted { font-size: 13px; line-height: 1.4; }

  @media (max-width: 900px) {
    .comparison-table { font-size: 14px; }
    .comparison-table th, .comparison-table td { padding: 16px 20px; }
  }
  @media (max-width: 720px) {
    .comparison-table-wrapper { margin: 24px -24px; }
    .comparison-table { display: block; border-radius: 0; border-left: none; border-right: none; }
    .comparison-table thead { display: none; }
    .comparison-table tbody { display: block; }
    .comparison-table tr { display: block; padding: 20px; border-bottom: 1px solid var(--border); }
    .comparison-table td { display: block; padding: 8px 0; border: none; }
    .comparison-table td:first-child { font-weight: 800; color: var(--brand-2); }
  }

  /* -------------------------- Pros List -------------------------- */
  .pros-list { display: grid; gap: 24px; margin-top: 32px; }
  .pro-item { display: flex; gap: 16px; align-items: flex-start; }
  .pro-item.featured { background: var(--surface); padding: 24px; border-radius: var(--radius); border: 1px solid var(--border); }
  .pro-icon {
    width: 40px; height: 40px; border-radius: 50%;
    display: grid; place-items: center;
    font-weight: 800; font-size: 18px;
    background: var(--brand-grad); color: #fff;
    flex-shrink: 0;
  }
  .pro-item h3 { font-size: 18px; margin-bottom: 8px; }
  .pro-item p { font-size: 15px; }

  /* ------------------------ Pricing Comparison --------------------- */
  .pricing-comparison { display: grid; grid-template-columns: repeat(2, minmax(0, 360px)); gap: 24px; justify-content: center; margin-top: 40px; }
  .pricing-card { position: relative; display: flex; flex-direction: column; }
  .pricing-featured { border-color: var(--brand); box-shadow: 0 0 0 1px var(--brand), 0 20px 50px rgba(124,58,237,0.25); }
  .pricing-badge {
    position: absolute; top: -12px; right: 22px;
    background: var(--brand-grad); color: #fff;
    font-size: 12px; font-weight: 700; padding: 5px 12px; border-radius: 999px;
  }
  .pricing-card h3 { font-size: 18px; margin-bottom: 20px; }
  .pricing-model { display: grid; gap: 12px; margin-bottom: 20px; }
  .price-row { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .price-label { font-weight: 600; }
  .price-value { font-weight: 800; font-size: 18px; }
  .price-save { font-size: 12px; color: #10b981; font-weight: 700; }
  .pricing-features { list-style: none; padding: 0; margin: 0 0 24px; display: grid; gap: 10px; font-size: 15px; }
  .pricing-note { font-size: 13px; line-height: 1.4; margin-top: auto; }
  .pricing-card .btn { margin-top: auto; }

  @media (max-width: 720px) { .pricing-comparison { grid-template-columns: 1fr; } }

  /* ----------------------------- Final CTA -------------------------- */
  .final-cta { padding: 92px 0; text-align: center; background:
      radial-gradient(60% 120% at 50% 0%, rgba(124, 58, 237, 0.22), transparent 70%); }
  .final-cta h2 { font-size: clamp(30px, 5vw, 48px); font-weight: 900; margin-bottom: 14px; }
  .final-cta p { margin-bottom: 30px; }
  .btn-lg { padding: 18px 36px; font-size: 18px; }

  /* ------------------------------ Footer ---------------------------- */
  .site-footer { border-top: 1px solid var(--border); padding: 48px 0 32px; background: var(--bg-soft); }
  .footer-inner { display: flex; justify-content: space-between; gap: 28px; flex-wrap: wrap; }
  .footer-brand { display: flex; align-items: center; gap: 8px; font-weight: 800; flex-wrap: wrap; }
  .footer-tag { width: 100%; font-weight: 400; font-size: 14px; margin: 6px 0 0; }
  .footer-links { display: flex; gap: 24px; flex-wrap: wrap; align-items: center; color: var(--muted); font-weight: 500; }
  .footer-links a:hover { color: var(--text); }
  .footer-legal { margin-top: 28px; font-size: 13px; }
</style>
