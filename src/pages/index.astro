---
import Layout from '../layouts/Layout.astro';
import {
  hero,
  stats,
  features,
  steps,
  supportedSites,
  testimonial,
  pricing,
  faq,
  finalCta,
  site,
  CHROME_STORE_URL,
  DISCORD_URL,
} from '../data/content';
---

<Layout>
  <!-- ============================ HEADER ============================ -->
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/" aria-label={`${site.name} home`}>
        <span class="brand-mark">🔍</span>
        <span class="brand-name">{site.name}</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#features">Features</a>
        <a href="#how-it-works">How it works</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
      </nav>
      <a class="btn btn-primary btn-sm js-cta" data-cta="header" href={CHROME_STORE_URL}>
        Add to Chrome
      </a>
    </div>
  </header>

  <main>
    <!-- ============================ HERO ============================ -->
    <section class="hero">
      <div class="container hero-inner">
        <span class="eyebrow">{hero.eyebrow}</span>
        <h1 class="hero-title">
          {hero.headline.split(' ').slice(0, -2).join(' ')}
          <span class="gradient-text">{hero.headline.split(' ').slice(-2).join(' ')}</span>
        </h1>
        <p class="hero-sub muted">{hero.subhead}</p>
        <div class="hero-cta">
          <a class="btn btn-primary js-cta" data-cta="hero-primary" href={hero.primaryCta.href}>
            ⚡ {hero.primaryCta.label}
          </a>
          <a class="btn btn-ghost" href={hero.secondaryCta.href}>{hero.secondaryCta.label}</a>
        </div>
        <ul class="microtrust">
          {hero.microtrust.map((t) => <li>✓ {t}</li>)}
        </ul>

        <!-- Lightweight visual: a stylized "before / after" bubble translation -->
        <div class="hero-demo" aria-hidden="true">
          <div class="panel">
            <div class="bubble jp">日本語のセリフ</div>
            <div class="bubble en">"Now I can read it!"</div>
            <div class="scan"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================ STATS ============================ -->
    <section class="stats-strip">
      <div class="container stats-grid">
        {stats.map((s) => (
          <div class="stat">
            <div class="stat-value gradient-text">{s.value}</div>
            <div class="stat-label muted">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== SUPPORTED SITES ==================== -->
    <section class="logos">
      <div class="container">
        <p class="logos-label muted">Works on the manga sites you already read</p>
        <ul class="logos-row">
          {supportedSites.map((s) => <li>{s}</li>)}
          <li class="more">+ hundreds more</li>
        </ul>
      </div>
    </section>

    <!-- ============================ FEATURES ============================ -->
    <section id="features" class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Features</span>
          <h2>Everything you need to read raw manga</h2>
          <p class="muted">Translate any page in a click — without leaving the site or losing the art.</p>
        </div>
        <div class="feature-grid">
          {features.map((f) => (
            <article class="card feature">
              <div class="feature-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              <p class="muted">{f.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ========================= HOW IT WORKS ========================= -->
    <section id="how-it-works" class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">How it works</span>
          <h2>Three steps to translated manga</h2>
        </div>
        <div class="steps">
          {steps.map((s) => (
            <div class="step">
              <div class="step-n">{s.n}</div>
              <h3>{s.title}</h3>
              <p class="muted">{s.body}</p>
            </div>
          ))}
        </div>
        <div class="center">
          <a class="btn btn-primary js-cta" data-cta="how-it-works" href={CHROME_STORE_URL}>
            ⚡ {hero.primaryCta.label}
          </a>
        </div>
      </div>
    </section>

    <!-- ========================= TESTIMONIAL ========================= -->
    <section class="section testimonial">
      <div class="container narrow center">
        <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
        <blockquote>“{testimonial.quote}”</blockquote>
        <cite class="muted">— {testimonial.source}</cite>
      </div>
    </section>

    <!-- ============================ PRICING ============================ -->
    <section id="pricing" class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Pricing</span>
          <h2>Simple, honest pricing</h2>
          <p class="muted">{pricing.freeNote}</p>
        </div>
        <div class="pricing-grid">
          {pricing.plans.map((p) => (
            <article class={`card plan ${p.highlight ? 'plan-featured' : ''}`}>
              {p.badge && <span class="plan-badge">{p.badge}</span>}
              <h3 class="plan-name">{p.name}</h3>
              <div class="plan-price">
                <span class="amount">{p.price}</span>
                <span class="period muted">{p.period}</span>
              </div>
              <ul class="plan-perks">
                {p.perks.map((perk) => <li>✓ {perk}</li>)}
              </ul>
              <a
                class={`btn js-cta ${p.highlight ? 'btn-primary' : 'btn-ghost'}`}
                data-cta={`pricing-${p.name.toLowerCase()}`}
                href={p.cta.href}
              >
                {p.cta.label}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================ FAQ ============================ -->
    <section id="faq" class="section">
      <div class="container narrow">
        <div class="section-head">
          <span class="eyebrow">FAQ</span>
          <h2>Questions, answered</h2>
        </div>
        <div class="faq-list">
          {faq.map((item) => (
            <details class="faq-item">
              <summary>{item.q}</summary>
              <p class="muted">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ========================= FINAL CTA ========================= -->
    <section class="final-cta">
      <div class="container center">
        <h2>{finalCta.headline}</h2>
        <p class="muted">{finalCta.subhead}</p>
        <a class="btn btn-primary btn-lg js-cta" data-cta="final" href={finalCta.cta.href}>
          ⚡ {finalCta.cta.label}
        </a>
      </div>
    </section>
  </main>

  <!-- ============================ FOOTER ============================ -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="brand-mark">🔍</span>
        <span class="brand-name">{site.name}</span>
        <p class="muted footer-tag">{site.tagline}</p>
      </div>
      <nav class="footer-links" aria-label="Footer">
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
        <a class="js-cta" data-cta="footer-discord" href={DISCORD_URL}>💬 Join Discord</a>
        <a class="js-cta" data-cta="footer-store" href={CHROME_STORE_URL}>Add to Chrome</a>
      </nav>
    </div>
    <div class="container footer-legal muted">
      © {new Date().getFullYear()} {site.name}. All rights reserved.
    </div>
  </footer>
</Layout>

<style>
  /* ----------------------------- Header ----------------------------- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(11, 11, 18, 0.7);
    border-bottom: 1px solid var(--border);
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; height: 66px; gap: 16px; }
  .brand { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 18px; }
  .brand-mark { font-size: 20px; }
  .nav-links { display: flex; gap: 28px; font-weight: 500; color: var(--muted); }
  .nav-links a:hover { color: var(--text); }
  .btn-sm { padding: 9px 18px; font-size: 14px; }
  @media (max-width: 760px) { .nav-links { display: none; } }

  /* ------------------------------ Hero ------------------------------ */
  .hero { position: relative; padding: 80px 0 64px; overflow: hidden; }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(60% 50% at 50% 0%, rgba(124, 58, 237, 0.25), transparent 70%),
      radial-gradient(40% 40% at 80% 10%, rgba(236, 72, 153, 0.18), transparent 70%);
    pointer-events: none;
  }
  .hero-inner { position: relative; text-align: center; max-width: 820px; margin: 0 auto; }
  .hero-title { font-size: clamp(40px, 7vw, 72px); font-weight: 900; }
  .hero-sub { font-size: clamp(17px, 2.4vw, 21px); margin: 22px auto 0; max-width: 620px; }
  .hero-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-top: 32px; }
  .microtrust {
    list-style: none; padding: 0; margin: 22px 0 0;
    display: flex; gap: 22px; justify-content: center; flex-wrap: wrap;
    font-size: 14px; color: var(--muted);
  }

  /* Hero demo visual */
  .hero-demo { margin: 56px auto 0; max-width: 520px; }
  .panel {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 20px;
    border: 1px solid var(--border);
    background:
      repeating-linear-gradient(135deg, #1b1b2b 0 14px, #16161f 14px 28px);
    box-shadow: 0 30px 80px rgba(0,0,0,0.5);
    overflow: hidden;
  }
  .bubble {
    position: absolute;
    padding: 10px 16px;
    border-radius: 14px;
    font-weight: 700;
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
  }
  .bubble.jp { top: 22%; left: 12%; background: #fff; color: #111; opacity: 0.55; }
  .bubble.en {
    bottom: 20%; right: 10%;
    background: var(--brand-grad); color: #fff;
  }
  .scan {
    position: absolute; left: 0; right: 0; top: 0; height: 3px;
    background: linear-gradient(90deg, transparent, var(--brand-2), transparent);
    animation: scan 3.2s ease-in-out infinite;
  }
  @keyframes scan { 0%,100% { top: 4%; } 50% { top: 92%; } }
  @media (prefers-reduced-motion: reduce) { .scan { animation: none; } }

  /* ------------------------------ Stats ----------------------------- */
  .stats-strip { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--bg-soft); }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; padding: 36px 24px; }
  .stat { text-align: center; }
  .stat-value { font-size: clamp(26px, 4vw, 38px); font-weight: 900; }
  .stat-label { font-size: 14px; }
  @media (max-width: 560px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }

  /* --------------------------- Logos strip -------------------------- */
  .logos { padding: 44px 0; }
  .logos-label { text-align: center; font-size: 14px; margin: 0 0 20px; }
  .logos-row {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 14px 30px; justify-content: center;
    font-weight: 700; color: #cfcfe0;
  }
  .logos-row .more { color: var(--muted); font-weight: 500; }

  /* --------------------------- Section heads ------------------------ */
  .section-alt { background: var(--bg-soft); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .section-head { text-align: center; max-width: 640px; margin: 0 auto 48px; }
  .section-head h2 { font-size: clamp(28px, 4.4vw, 42px); font-weight: 800; margin-bottom: 14px; }
  .narrow { max-width: 760px; }
  .center { text-align: center; }

  /* ------------------------------ Cards ----------------------------- */
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 26px; }

  .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .feature-icon { font-size: 28px; margin-bottom: 14px; }
  .feature h3 { font-size: 19px; margin-bottom: 8px; }
  .feature p { font-size: 15px; }
  @media (max-width: 900px) { .feature-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .feature-grid { grid-template-columns: 1fr; } }

  /* ---------------------------- How it works ------------------------ */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 44px; }
  .step-n {
    width: 44px; height: 44px; border-radius: 50%;
    display: grid; place-items: center;
    font-weight: 800; color: #fff; background: var(--brand-grad);
    margin-bottom: 16px;
  }
  .step h3 { font-size: 19px; margin-bottom: 8px; }
  @media (max-width: 720px) { .steps { grid-template-columns: 1fr; } }

  /* ---------------------------- Testimonial ------------------------- */
  .testimonial blockquote { font-size: clamp(20px, 3vw, 28px); font-weight: 600; margin: 14px 0; }
  .stars { color: #fbbf24; font-size: 22px; letter-spacing: 2px; }

  /* ------------------------------ Pricing --------------------------- */
  .pricing-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 360px)); gap: 24px; justify-content: center; }
  .plan { position: relative; display: flex; flex-direction: column; }
  .plan-featured { border-color: var(--brand); box-shadow: 0 0 0 1px var(--brand), 0 20px 50px rgba(124,58,237,0.25); }
  .plan-badge {
    position: absolute; top: -12px; right: 22px;
    background: var(--brand-grad); color: #fff;
    font-size: 12px; font-weight: 700; padding: 5px 12px; border-radius: 999px;
  }
  .plan-name { font-size: 18px; margin-bottom: 10px; }
  .plan-price { display: flex; align-items: baseline; gap: 6px; margin-bottom: 18px; }
  .plan-price .amount { font-size: 40px; font-weight: 900; }
  .plan-perks { list-style: none; padding: 0; margin: 0 0 24px; display: grid; gap: 10px; font-size: 15px; }
  .plan .btn { margin-top: auto; }
  @media (max-width: 720px) { .pricing-grid { grid-template-columns: 1fr; } }

  /* -------------------------------- FAQ ----------------------------- */
  .faq-list { display: grid; gap: 12px; }
  .faq-item { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 4px 20px; }
  .faq-item summary {
    cursor: pointer; font-weight: 600; padding: 16px 0; list-style: none;
    display: flex; justify-content: space-between; align-items: center;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 22px; color: var(--brand-2); }
  .faq-item[open] summary::after { content: '–'; }
  .faq-item p { margin: 0 0 16px; }

  /* ----------------------------- Final CTA -------------------------- */
  .final-cta { padding: 92px 0; text-align: center; background:
      radial-gradient(60% 120% at 50% 0%, rgba(124, 58, 237, 0.22), transparent 70%); }
  .final-cta h2 { font-size: clamp(30px, 5vw, 48px); font-weight: 900; margin-bottom: 14px; }
  .final-cta p { margin-bottom: 30px; }
  .btn-lg { padding: 18px 36px; font-size: 18px; }

  /* ------------------------------ Footer ---------------------------- */
  .site-footer { border-top: 1px solid var(--border); padding: 48px 0 32px; background: var(--bg-soft); }
  .footer-inner { display: flex; justify-content: space-between; gap: 28px; flex-wrap: wrap; }
  .footer-brand { display: flex; align-items: center; gap: 8px; font-weight: 800; flex-wrap: wrap; }
  .footer-tag { width: 100%; font-weight: 400; font-size: 14px; margin: 6px 0 0; }
  .footer-links { display: flex; gap: 24px; flex-wrap: wrap; align-items: center; color: var(--muted); font-weight: 500; }
  .footer-links a:hover { color: var(--text); }
  .footer-legal { margin-top: 28px; font-size: 13px; }
</style>
